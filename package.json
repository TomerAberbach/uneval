{
  "name": "@tomer/uneval",
  "version": "0.0.0",
  "author": {
    "name": "Tomer Aberbach",
    "email": "tomer@aberba.ch",
    "url": "https://tomeraberba.ch"
  },
  "description": "Convert a JS value to JS source code.",
  "keywords": [
    "eval",
    "source",
    "stringify",
    "serialize",
    "roundtrip"
  ],
  "homepage": "https://github.com/TomerAberbach/uneval",
  "repository": "TomerAberbach/uneval",
  "bugs": {
    "url": "https://github.com/TomerAberbach/uneval/issues"
  },
  "funding": {
    "url": "https://github.com/sponsors/TomerAberbach"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">= 22"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "format": "prettier --cache --write .",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "bench": "vitest bench",
    "build": "tsdown",
    "prepublishOnly": "pnpm build"
  },
  "prettier": "@tomer/prettier-config",
  "devDependencies": {
    "@fast-check/vitest": "^0.2.4",
    "@rollup/plugin-terser": "^0.4.4",
    "@tomer/eslint-config": "^4.5.0",
    "@tomer/prettier-config": "^4.0.0",
    "@types/jsesc": "^3.0.3",
    "@types/serialize-javascript": "^5.0.4",
    "@vitest/coverage-v8": "^4.0.6",
    "devalue": "^5.6.2",
    "eslint": "^9.39.2",
    "jest-extended": "^7.0.0",
    "jsdom": "^28.0.0",
    "jsesc": "^3.1.0",
    "magic-string": "^0.30.21",
    "prettier": "^3.8.1",
    "publint": "^0.3.17",
    "serialize-javascript": "^7.0.2",
    "tosource": "2.0.0-alpha.3",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  }
}
